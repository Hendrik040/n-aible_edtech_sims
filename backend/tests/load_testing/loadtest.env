# =============================================================================
# Load Testing Environment Configuration
# =============================================================================
# Copy this file to loadtest.env in the same directory:
#   cp loadtest.env.example loadtest.env
#
# This file configures load tests against your Railway deployment.
# =============================================================================

# -----------------------------------------------------------------------------
# TARGET ENVIRONMENT
# -----------------------------------------------------------------------------
# The URL of the backend to test against
# - For staging: Use your Railway staging URL
# - For local: Use http://localhost:8000
# - NEVER run load tests against production!
LOAD_TEST_URL=https://backend-development-0519.up.railway.app

# Environment identifier (for logging/reports)
# Options: local, staging, production (production will be blocked)
LOAD_TEST_ENVIRONMENT=staging

# -----------------------------------------------------------------------------
# TEST USER CONFIGURATION
# -----------------------------------------------------------------------------
# Test users should be pre-created in the database with this pattern:
# Email: {prefix}{number}{domain} -> loadtest_user_1@test.com
#
# SQL to create test users:
# INSERT INTO users (email, full_name, hashed_password, is_verified, created_at)
# SELECT 
#     'loadtest_user_' || generate_series || '@test.com',
#     'Load Test User ' || generate_series,
#     '$2b$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/X4hJQKYUFocFZOAGe',
#     true, NOW()
# FROM generate_series(1, 100);

TEST_USER_PREFIX=loadtest_user_opt
TEST_USER_DOMAIN=@testnew.com
TEST_USER_PASSWORD=testpassword123

# Number of test users available (should match what's in the database)
TEST_USER_COUNT=100

# -----------------------------------------------------------------------------
# TEST DATA CONFIGURATION
# -----------------------------------------------------------------------------
# The simulation ID to test against (must be published and accessible)
TEST_SIMULATION_ID=1

# The cohort ID that test users are enrolled in
TEST_COHORT_ID=1

# -----------------------------------------------------------------------------
# LOAD TEST PARAMETERS
# -----------------------------------------------------------------------------
# Default values - can be overridden via CLI arguments

# Wait time between user actions (seconds)
MIN_WAIT_TIME=5
MAX_WAIT_TIME=15

# Default number of concurrent users
DEFAULT_USERS=100

# Users spawned per second
DEFAULT_SPAWN_RATE=2

# Default test duration (e.g., 2m, 15m, 1h)
DEFAULT_RUN_TIME=15m

# -----------------------------------------------------------------------------
# TIMEOUTS
# -----------------------------------------------------------------------------
# Request timeouts in seconds
LOGIN_TIMEOUT=10
CHAT_TIMEOUT=60
GRADING_TIMEOUT=120
POLL_TIMEOUT=10

# -----------------------------------------------------------------------------
# REPORTING
# -----------------------------------------------------------------------------
# Generate HTML report after test
GENERATE_HTML_REPORT=true

# Generate CSV files after test
GENERATE_CSV_REPORT=true

# Reports directory (relative to load_testing folder)
REPORTS_DIR=reports

# -----------------------------------------------------------------------------
# ADVANCED OPTIONS
# -----------------------------------------------------------------------------
# Enable verbose logging
VERBOSE=false

# Stop test if error rate exceeds this percentage
MAX_ERROR_RATE=10

# Log individual request failures
LOG_FAILURES=true

# set debug mode
DEBUG_MODE=true